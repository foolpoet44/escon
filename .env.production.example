# ============================================================================
# ESCON Production Environment Variables
# ============================================================================
#
# 이 파일은 프로덕션 환경 설정의 템플릿입니다.
# Vercel 대시보드에서 직접 설정하세요.
#
# 설정 방법:
# 1. Vercel 대시보드 → Project Settings → Environment Variables
# 2. 각 변수를 아래 형식으로 추가
#

# ============================================================================
# Supabase 설정 (필수)
# ============================================================================

# Supabase 프로젝트 URL
# 예: https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase 익명 키 (클라이언트 사이드에서 사용)
# 프로젝트 설정 → API에서 확인 가능
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase 서비스 역할 키 (서버 사이드 전용)
# 프로젝트 설정 → API에서 확인 가능
# ⚠️ 절대 클라이언트에 노출하지 말 것
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# LLM 설정 (선택)
# ============================================================================

# LLM 제공자: gemini | claude | openai
# 기본값: gemini (Gemini Flash 2.5 사용)
LLM_PROVIDER=gemini

# LLM 모델명
# Gemini: gemini-2.5-flash
# Claude: claude-sonnet-4-6
# OpenAI: gpt-4-turbo
LLM_MODEL=gemini-2.5-flash

# LLM API 키 (선택 제공자에 따라)
# Gemini API Key: https://aistudio.google.com/app/apikey
# Claude API Key: https://console.anthropic.com/
# OpenAI API Key: https://platform.openai.com/api-keys
LLM_API_KEY=your-llm-api-key

# ============================================================================
# 애플리케이션 설정
# ============================================================================

# 애플리케이션 환경: development | staging | production
NODE_ENV=production

# 디버그 모드: true | false
# 프로덕션에서는 false로 설정
DEBUG=false

# ============================================================================
# 모니터링 설정 (선택)
# ============================================================================

# Sentry DSN (에러 추적)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Vercel Analytics (성능 모니터링)
VERCEL_ANALYTICS_ID=

# ============================================================================
# 배포 설정
# ============================================================================

# 배포 환경: preview | production
VERCEL_ENV=production

# 배포 URL (Vercel 자동 설정)
# VERCEL_URL=

# Git 정보 (Vercel 자동 설정)
# VERCEL_GIT_COMMIT_SHA=
# VERCEL_GIT_BRANCH=

# ============================================================================
# 주의사항
# ============================================================================
#
# 1. 민감한 정보 (API 키 등)는 절대 GitHub에 커밋하지 말 것
# 2. Vercel 대시보드에서 환경 변수 암호화 지원
# 3. 각 환경(Preview/Production)마다 다른 값 설정 가능
# 4. 환경 변수 변경 후 새로 배포 필요
#
