{
    "organization": {
        "id": "vision_inspection",
        "name": "비전검사 자동화 Task",
        "name_en": "Vision Inspection Automation Task Force",
        "description": "AI 비전 기반 제품 외관 검사 자동화 시스템 개발 및 운영",
        "mission": "딥러닝 기반 비전 검사로 불량 검출 정확도 향상 및 검사 인력 최적화",
        "mission_detail": "비전검사 자동화 Task는 제조 라인에서 딥러닝 기반 이미지 분석으로 제품 외관 불량을 실시간 검출하는 시스템을 구축한다. 기존 룰 기반 검사의 한계를 극복하고, 현장 엔지니어가 자체적으로 검사 모델을 학습·배포할 수 있는 MLOps 파이프라인을 제공한다.",
        "challenges": [
            {
                "title": "다양한 불량 유형 대응",
                "items": [
                    "제품/공정별 불량 패턴이 매우 다양",
                    "신제품 투입 시 빠른 모델 재학습 필요"
                ]
            },
            {
                "title": "현장 환경 적응",
                "items": [
                    "조명/진동/온도 등 환경 변화에 강건한 검사 필요",
                    "라인 속도에 맞춘 실시간 처리 성능 확보"
                ]
            }
        ],
        "value_propositions": [
            {
                "title": "딥러닝 기반 불량 검출",
                "description": "CNN/Transformer 기반 이미지 분류 및 세그멘테이션\n미세 결함까지 99%+ 검출률"
            },
            {
                "title": "현장 MLOps 파이프라인",
                "description": "엔지니어가 직접 데이터 라벨링·모델 학습 가능\n모델 버전 관리 및 자동 배포"
            },
            {
                "title": "환경 변화 자동 보정",
                "description": "조명 보정 및 이미지 정규화 자동화\n도메인 적응 기법으로 환경 변화 대응"
            }
        ],
        "roles": [
            "비전 검사 알고리즘 개발 및 최적화",
            "카메라/조명 시스템 설계 및 교정",
            "MLOps 파이프라인 구축 및 운영",
            "검사 결과 대시보드 및 리포팅 시스템 개발",
            "현장 엔지니어 모델 학습 도구 제공"
        ],
        "expectations": [
            "불량 검출률 99.5% 이상 달성",
            "오검출률 (False Positive) 0.1% 이하",
            "신제품 검사 모델 학습 시간 1일 이내",
            "검사 인력 50% 최적화"
        ],
        "conclusion": {
            "slogan": "\"사람 눈을 넘어서는 AI 검사,\n현장 엔지니어가 직접 키우는 검사 모델\"",
            "description": "비전검사 자동화 Task가 만들어가는 미래입니다."
        }
