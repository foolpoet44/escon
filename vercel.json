{
  "projectSettings": {
    "name": "escon",
    "framework": "nextjs"
  },
  "buildHook": {
    "enabled": true,
    "requiresApproval": false
  },
  "regions": ["iad1"],
  "functions": {
    "api/**": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/robot-smartfactory",
      "permanent": false
    }
  ]
}
